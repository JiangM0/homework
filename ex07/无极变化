#include <WiFi.h>
#include <WebServer.h>

const char* ssid     = "你的WiFi名称";
const char* password = "你的WiFi密码";

WebServer server(80);

const int ledPin = 2;
int brightness = 0;

const char* html = R"HTML(
<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">
<title>ESP32 PWM 调光器</title>
<style>
body{text-align:center;margin-top:50px;font-size:22px;}
input{width:300px;}
</style>
</head>
<body>
  <h2>ESP32 无极调光</h2>
  <p>亮度值：<span id="val">0</span></p>
  <input type="range" min="0" max="255" value="0" id="slider">

<script>
const slider = document.getElementById('slider');
const val    = document.getElementById('val');

slider.addEventListener('input', function(){
  let value = this.value;
  val.textContent = value;
  fetch('/set?brightness=' + value);
});
</script>
</body>
</html>
)HTML";

void handleRoot() {
  server.send(200, "text/html", html);
}

void handleSet() {
  if (server.hasArg("brightness")) {
    int val = server.arg("brightness").toInt();
    if (val >= 0 && val <= 255) {
      brightness =  val;  // 低电平亮
    }
    server.send(200, "text/plain", String(val));
  } else {
    server.send(400, "text/plain", "error");
  }
}

void setup() {
  Serial.begin(115200);
  pinMode(ledPin, OUTPUT);
  digitalWrite(ledPin, HIGH);  // 初始灭

  WiFi.begin(ssid, password);
  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }
  Serial.println("WiFi connected");
  Serial.println(WiFi.localIP());

  server.on("/", handleRoot);
  server.on("/set", handleSet);
  server.begin();
}

void loop() {
  server.handleClient();
  analogWrite(ledPin, brightness);
}